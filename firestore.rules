rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lobbies: any authenticated user can read/write
    match /lobbies/{roomCode} {
      allow read, write: if request.auth != null;

      match /players/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Games: any authenticated user can read; writes restricted to authenticated users
    // Full validation will move to Cloud Functions (server-authoritative)
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
